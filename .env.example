# ============================================================
# BASOL BOT v3.0 — SECRETS TEMPLATE
# File ini HANYA untuk API keys dan credentials sensitif.
# Untuk setting strategi (TP, SL, posisi, dll) → edit config.env
#
# Di Replit: isi via tab Secrets (lebih aman dari file ini)
# Di VPS   : salin ke .env lalu isi nilainya
# ============================================================

# === WAJIB — Bot crash tanpa ketiga key ini ===

# Helius API key — daftar gratis di https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# Telegram Bot Token — buat bot baru via @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID — cara dapat:
#   1. Kirim pesan apapun ke bot kamu
#   2. Buka: https://api.telegram.org/bot<TOKEN>/getUpdates
#   3. Cari nilai "chat":{"id": ANGKA_INI}
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === OPSIONAL — Helius Key Rotation ===
# Bot auto-rotate ke key berikutnya saat rate limit (429)
# Tambah key gratis dengan buat akun baru di helius.dev
# HELIUS_API_KEY_2=key_kedua
# HELIUS_API_KEY_3=key_ketiga
# Atau format comma-separated:
# HELIUS_API_KEYS=key1,key2,key3

# === OPSIONAL — Wallet (hanya perlu jika TRADING_ENABLED=true) ===
# Format: base58 string / hex string / JSON array [1,2,3,...]
# JANGAN gunakan wallet utama — buat wallet baru khusus bot
# WALLET_PRIVATE_KEY=your_private_key_here
