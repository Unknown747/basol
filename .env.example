# ============================================================
# ENV CONFIG - Salin file ini ke .env dan isi nilainya
# ============================================================

# === API KEYS (WAJIB) ===
# Helius API key - daftar gratis di https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# Telegram Bot Token - buat bot baru via @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID - ID chat/channel tujuan notifikasi
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === WALLET (WAJIB jika TRADING_ENABLED=true) ===
# Format bisa: base58 string, hex string, atau JSON array [1,2,3,...]
WALLET_PRIVATE_KEY=your_private_key_here

# === SOLANA RPC ===
# Default: mainnet-beta publik (lambat). Gunakan Helius untuk lebih cepat
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Contoh Helius RPC (direkomendasikan):
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ============================================================
# TRADING CONFIG — PRESET STANDAR (modal >= 0.5 SOL)
# ============================================================

# Master switch — set true untuk mengaktifkan auto buy/sell
# DEFAULT: false (AMAN - hanya analisis, tidak ada eksekusi)
TRADING_ENABLED=false

# Maksimal SOL per posisi
MAX_POSITION_SOL=0.5

# Ukuran posisi minimum (default: 10% dari MAX_POSITION_SOL, min 0.01 SOL)
# MIN_POSITION_SOL=0.05

# Take profit dalam persen
# [MATEMATIKA] Di TP 40%: net profit bersih ≈ 35% setelah biaya slippage+network
TAKE_PROFIT_PERCENT=40.0

# Stop loss dalam persen
# [MATEMATIKA] Di SL 15%: net loss bersih ≈ 18% setelah biaya
STOP_LOSS_PERCENT=15.0

# Trailing stop mulai aktif setelah profit X%
TRAILING_START_PERCENT=20.0

# Jarak trailing stop dari harga tertinggi (persen)
TRAILING_DISTANCE_PERCENT=5.0

# Skor minimum untuk auto buy (default: 85.0)
MIN_SCORE_TO_BUY=85.0

# Likuiditas minimum USD untuk auto buy
MIN_LIQUIDITY_USD=10000.0

# Slippage default dalam persen
DEFAULT_SLIPPAGE=1.0

# Maksimal posisi aktif bersamaan
MAX_POSITIONS=5

# Time exit: keluar otomatis jika posisi stuck lebih dari X menit
# 0 = dinonaktifkan (tahan selamanya)
MAX_HOLD_MINUTES=0

# Threshold P&L untuk time exit
# Keluar jika profit < nilai ini setelah MAX_HOLD_MINUTES
TIME_EXIT_THRESHOLD_PCT=5.0

# ============================================================
# ⚡ SCALPING PRESET — Optimal untuk modal kecil (0.05–0.2 SOL)
# ============================================================
# Hapus tanda # di depan semua baris di bawah ini untuk aktifkan scalping.
# Pastikan baris STANDAR di atas ikut dinonaktifkan/dihapus.
#
# === PERHITUNGAN BIAYA (per trade 0.05 SOL, pool $5k) ===
#
#   Biaya masuk  : slippage 1.5% + impact 0.17% + fee = 1.72% = 0.00086 SOL
#   Biaya keluar : slippage 1.5% + impact 0.20% + fee = 1.74% dari nilai jual
#   Break-even   : harga harus naik +3.81% hanya untuk balik modal biaya!
#
#   ┌─────────────────────────────────────────────────────────┐
#   │  SKENARIO          │  GROSS   │  BIAYA   │  NET BERSIH  │
#   ├─────────────────────────────────────────────────────────┤
#   │  TP tercapai (20%) │ +0.0100  │ -0.0019  │ +0.0081 SOL  │
#   │                    │ +20.0%   │          │ +16.2% bersih│
#   ├─────────────────────────────────────────────────────────┤
#   │  SL kena (8%)      │ -0.0040  │ -0.0016  │ -0.0056 SOL  │
#   │                    │ -8.0%    │          │ -11.3% bersih│
#   └─────────────────────────────────────────────────────────┘
#
#   Risk/Reward   : 1.43 (menguntungkan jika win rate > 41.1%)
#   Expected Value: +2.4% per trade di win rate 50%
#                   +3.8% per trade di win rate 55%
#
#   Trailing stop mulai 12%: jika harga naik ke 12% lalu turun 3%,
#   sell di +9% (masih profit bersih +5.2%) — tidak perlu tunggu TP!
#
# === CARA PAKAI TP DENGAN BENAR ===
#
#   TP bukan "target impian" — TP adalah titik aman mengunci profit.
#   Dengan trailing stop aktif di 12%:
#     → Naik 12% → trailing aktif, stop di 9%
#     → Naik 15% → stop naik ke 12% (terlindungi balik modal bersih)
#     → Naik 20% → TP fire, keluar di +16.2% bersih
#     → Naik 18% lalu balik → trailing stop kena di sekitar +15%
#   Artinya: TIDAK PERLU TEPAT SAMPAI 20%, trailing sudah jaga kamu!
#
#TRADING_ENABLED=false
#MAX_POSITION_SOL=0.05
#MIN_POSITION_SOL=0.05
#TAKE_PROFIT_PERCENT=20.0
#STOP_LOSS_PERCENT=8.0
#TRAILING_START_PERCENT=12.0
#TRAILING_DISTANCE_PERCENT=3.0
#MIN_SCORE_TO_BUY=87.0
#MIN_LIQUIDITY_USD=5000.0
#DEFAULT_SLIPPAGE=1.5
#MAX_POSITIONS=2
#MAX_HOLD_MINUTES=40
#TIME_EXIT_THRESHOLD_PCT=3.0

# ============================================================
# PAPER TRADING CONFIG (Simulasi tanpa uang nyata)
# ============================================================

# Aktifkan paper trading — AMAN, tidak pakai SOL sungguhan
PAPER_TRADING_ENABLED=false

# Saldo virtual SOL untuk paper trading
# Rekomendasi: set sama dengan modal nyata agar hasil simulasi akurat
PAPER_BALANCE_SOL=0.1

# Interval laporan otomatis ke Telegram (detik)
PAPER_REPORT_INTERVAL_SECS=3600

# Catatan: TP, SL, Trailing, dll diambil dari konfigurasi di atas.
# Untuk paper trading scalping: aktifkan preset scalping + PAPER_TRADING_ENABLED=true

# ============================================================
# BACKTESTING CONFIG (cargo run -- --backtest)
# ============================================================

# Jumlah token yang dianalisis dalam satu sesi backtest
BACKTEST_TOKEN_LIMIT=150

# Umur minimum token dalam jam
BACKTEST_MIN_AGE_HOURS=6

# Umur maksimum token dalam jam
BACKTEST_MAX_AGE_HOURS=72

# Likuiditas minimum untuk ikut backtest
BACKTEST_MIN_LIQUIDITY=5000.0

# Volume minimum 24 jam untuk ikut backtest
BACKTEST_MIN_VOLUME=10000.0

# Harga SOL dalam USD (diupdate otomatis oleh bot, ini hanya nilai awal)
SOL_PRICE_USD=170.0
