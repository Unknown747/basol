# ============================================================
# ENV CONFIG - Salin file ini ke .env dan isi nilainya
# Basol Bot v3.0 — https://github.com/Unknown747/Baxsol
# ============================================================

# === API KEYS (WAJIB) ===
# Helius API key utama - daftar gratis di https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# --- KEY ROTATION (Opsional tapi sangat direkomendasikan) ---
# Bot otomatis rotasi key saat 429 rate limit. Tambah key ke-2, ke-3, dst.
# Cara dapat lebih banyak key: buat akun baru di helius.dev (free per akun)
# Atau isi HELIUS_API_KEYS dengan format comma-separated sebagai alternatif:
# HELIUS_API_KEYS=key1,key2,key3
#
# HELIUS_API_KEY_2=your_second_helius_key_here
# HELIUS_API_KEY_3=your_third_helius_key_here
# HELIUS_API_KEY_4=your_fourth_helius_key_here
#
# Setiap key bebas rate-limit selama 65 detik setelah kena 429.
# Dengan 2 key: efektif 2x kapasitas request. Dengan 3 key: 3x, dst.
# Ketik /helius di Telegram untuk test semua key dan lihat statusnya.
# ---

# Telegram Bot Token - buat bot baru via @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID - ID chat/channel tujuan notifikasi
# Cara dapat: forward pesan ke @userinfobot, atau buka t.me/getidsbot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === WALLET (WAJIB jika TRADING_ENABLED=true) ===
# Format bisa: base58 string, hex string, atau JSON array [1,2,3,...]
# Tidak perlu isi ini untuk paper trading / analisis saja
WALLET_PRIVATE_KEY=your_private_key_here

# === SOLANA RPC ===
# Default: mainnet-beta publik (lambat, rate-limited). Gunakan Helius untuk lebih cepat
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Direkomendasikan — Helius RPC (ganti YOUR_HELIUS_KEY dengan key di atas):
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ============================================================
# TRADING CONFIG — PRESET STANDAR (modal >= 0.5 SOL)
# ============================================================

# Master switch — set true untuk mengaktifkan auto buy/sell on-chain
# DEFAULT: false (AMAN - hanya analisis, tidak ada eksekusi)
TRADING_ENABLED=false

# Maksimal SOL per posisi
MAX_POSITION_SOL=0.5

# Ukuran posisi minimum (default: 10% dari MAX_POSITION_SOL, min 0.01 SOL)
# MIN_POSITION_SOL=0.05

# Take profit dalam persen
# [MATEMATIKA] Di TP 40%: net profit bersih ≈ 35% setelah biaya slippage+network
TAKE_PROFIT_PERCENT=40.0

# Stop loss dalam persen
# [MATEMATIKA] Di SL 15%: net loss bersih ≈ 18% setelah biaya
STOP_LOSS_PERCENT=15.0

# Trailing stop mulai aktif setelah profit X%
TRAILING_START_PERCENT=20.0

# Jarak trailing stop dari harga tertinggi (persen)
TRAILING_DISTANCE_PERCENT=5.0

# Skor minimum untuk auto buy (0-100)
# Bot auto-adjust nilai ini setiap jam berdasarkan win rate terakhir
MIN_SCORE_TO_BUY=85.0

# Likuiditas minimum USD untuk auto buy
MIN_LIQUIDITY_USD=10000.0

# Slippage default dalam persen
DEFAULT_SLIPPAGE=1.0

# Maksimal posisi aktif bersamaan
MAX_POSITIONS=5

# Time exit: keluar otomatis jika posisi stuck lebih dari X menit
# 0 = dinonaktifkan (tahan selamanya)
MAX_HOLD_MINUTES=0

# Threshold P&L untuk time exit
# Keluar jika profit < nilai ini setelah MAX_HOLD_MINUTES
TIME_EXIT_THRESHOLD_PCT=5.0

# ============================================================
# 3-STAGE TAKE PROFIT (Partial TP)
# ============================================================
# Jual posisi secara bertahap — "tidak serakah, amankan profit dulu"
#
# Cara kerja:
#   TP1 → jual TP1_SELL_PERCENT% dari posisi di level TP1_PERCENT%
#   TP2 → jual TP2_SELL_PERCENT% dari SISA posisi di level TP2_PERCENT%
#   TP Final (TAKE_PROFIT_PERCENT) → jual semua sisa posisi
#   SL  → selalu jual 100% sekarang juga (tidak pernah partial)
#
# Set TP1_PERCENT=0 untuk nonaktifkan dan pakai single TP biasa.

# Level TP tahap 1 (default 0.0 = nonaktif)
# PENTING: harus > break-even (~3.81% untuk 0.03 SOL + slippage 1.5%)
TP1_PERCENT=0.0

# Berapa persen posisi dijual di TP1
TP1_SELL_PERCENT=33.0

# Level TP tahap 2 (default 0.0 = nonaktif)
TP2_PERCENT=0.0

# Berapa persen SISA posisi dijual di TP2
TP2_SELL_PERCENT=50.0

# ============================================================
# ⚡ SCALPING PRESET — Optimal untuk modal kecil (0.03–0.1 SOL)
# ============================================================
# Hapus tanda # di depan semua baris di bawah ini untuk aktifkan scalping.
# Pastikan baris STANDAR di atas ikut dinonaktifkan/dihapus.
#
# === PERHITUNGAN BIAYA (per trade 0.03 SOL, pool $5k) ===
#
#   Biaya masuk  : slippage 1.5% + impact 0.10% + fee = 1.63% = 0.00049 SOL
#   Biaya keluar : slippage 1.5% + impact 0.12% + fee = 1.65% dari nilai jual
#   Break-even   : harga harus naik +3.81% hanya untuk balik modal biaya!
#
#   ┌─────────────────────────────────────────────────────────┐
#   │  SKENARIO          │  GROSS   │  BIAYA   │  NET BERSIH  │
#   ├─────────────────────────────────────────────────────────┤
#   │  TP tercapai (35%) │ +0.0105  │ -0.0011  │ +0.0094 SOL  │
#   │                    │ +35.0%   │          │ +31.2% bersih│
#   ├─────────────────────────────────────────────────────────┤
#   │  SL kena (8%)      │ -0.0024  │ -0.0009  │ -0.0033 SOL  │
#   │                    │ -8.0%    │          │ -11.1% bersih│
#   └─────────────────────────────────────────────────────────┘
#
#   Risk/Reward   : 2.82 (menguntungkan jika win rate > 28.2%)
#   Expected Value: +5.2% per trade di win rate 40%
#
#   Trailing stop mulai 12%: jika harga naik ke 12% lalu turun 3%,
#   sell di +9% (masih profit bersih +5.2%) — tidak perlu tunggu TP!
#
# === CARA PAKAI TP DENGAN BENAR ===
#
#   TP bukan "target impian" — TP adalah titik aman mengunci profit.
#   Dengan trailing stop aktif di 12%:
#     → Naik 12% → trailing aktif, stop di 9%
#     → Naik 15% → stop naik ke 12% (terlindungi balik modal bersih)
#     → Naik 35% → TP fire, keluar di +31.2% bersih
#     → Naik 18% lalu balik → trailing stop kena di sekitar +15%
#   Artinya: TIDAK PERLU TEPAT SAMPAI 35%, trailing sudah jaga kamu!
#
#TRADING_ENABLED=false
#MAX_POSITION_SOL=0.03
#MIN_POSITION_SOL=0.03
#TAKE_PROFIT_PERCENT=35.0
#STOP_LOSS_PERCENT=8.0
#TRAILING_START_PERCENT=12.0
#TRAILING_DISTANCE_PERCENT=3.0
#MIN_SCORE_TO_BUY=89.0
#MIN_LIQUIDITY_USD=5000.0
#DEFAULT_SLIPPAGE=1.5
#MAX_POSITIONS=2
#MAX_HOLD_MINUTES=40
#TIME_EXIT_THRESHOLD_PCT=3.0
#
# === 3-STAGE TP (aktif bersamaan dengan scalping preset di atas) ===
#TP1_PERCENT=12.0
#TP1_SELL_PERCENT=33.0
#TP2_PERCENT=20.0
#TP2_SELL_PERCENT=50.0

# ============================================================
# PAPER TRADING CONFIG (Simulasi tanpa uang nyata)
# ============================================================

# Aktifkan paper trading — AMAN, tidak pakai SOL sungguhan
# Rekomendasi: jalankan paper trading dulu sebelum live trading
PAPER_TRADING_ENABLED=false

# Saldo virtual SOL untuk paper trading
# Set sama dengan modal nyata agar hasil simulasi akurat
PAPER_BALANCE_SOL=0.1

# Interval laporan otomatis ke Telegram (detik, default 1 jam)
PAPER_REPORT_INTERVAL_SECS=3600

# Catatan: TP, SL, Trailing, MIN_SCORE, dll diambil dari konfigurasi di atas.
# Paper trading dan live trading pakai config yang IDENTIK by design.

# ============================================================
# SMART PROTECTION FEATURES (v3.0)
# ============================================================

# === CIRCUIT BREAKER ===
# Auto-pause buy scanning setelah N kerugian berturut-turut
# Bot tetap monitor & eksekusi sell posisi yang sudah ada
# Contoh: 3 loss berturut → pause beli 2 jam → resume otomatis
CIRCUIT_BREAKER_LOSSES=3

# Durasi pause circuit breaker dalam jam
CIRCUIT_BREAKER_PAUSE_HOURS=2

# === PEAK HOURS FILTER ===
# Jika true: hanya beli token selama jam volume tinggi
# Window 1: 13:00-17:00 UTC (London/NY overlap — volume paling tinggi)
# Window 2: 20:00-00:00 UTC (US evening session)
# Sell monitoring tetap jalan 24 jam penuh
# false = beli kapan saja tanpa filter jam (default)
PEAK_HOURS_ONLY=false

# === MOMENTUM FILTER ===
# Skip token yang sudah pump lebih dari X% dalam 1 jam terakhir
# Entry sudah terlambat, risiko dump tinggi
# Nilai kecil = lebih selektif (misal 20.0 = skip jika sudah +20% dalam 1h)
MOMENTUM_MAX_PCT=30.0

# ============================================================
# TELEGRAM COMMANDS (v3.0) — no extra config needed
# ============================================================
# Bot otomatis merespons perintah berikut di TELEGRAM_CHAT_ID:
#
#   /status        — status bot, posisi, win rate, P&L, circuit breaker
#   /pause         — hentikan buy scanning manual (sell tetap jalan)
#   /resume        — lanjutkan scanning + reset circuit breaker
#   /trades        — tampilkan 10 paper trade terakhir
#   /score         — score threshold saat ini vs nilai base
#   /blacklist     — tampilkan jumlah token di-blacklist
#   /blacklist <addr> — tambahkan token ke blacklist (skip permanent)
#
# Tidak perlu config tambahan. Token blacklist disimpan di bot_data.json.

# ============================================================
# BACKTESTING CONFIG (cargo run -- --backtest)
# ============================================================

# Jumlah token yang dianalisis dalam satu sesi backtest
BACKTEST_TOKEN_LIMIT=150

# Umur minimum token dalam jam
BACKTEST_MIN_AGE_HOURS=6

# Umur maksimum token dalam jam
BACKTEST_MAX_AGE_HOURS=72

# Likuiditas minimum untuk ikut backtest
BACKTEST_MIN_LIQUIDITY=5000.0

# Volume minimum 24 jam untuk ikut backtest
BACKTEST_MIN_VOLUME=10000.0

# Harga SOL dalam USD (diupdate otomatis oleh bot, ini hanya nilai awal)
SOL_PRICE_USD=170.0
