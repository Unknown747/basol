# ============================================================
# ENV CONFIG - Salin file ini ke .env dan isi nilainya
# ============================================================

# === WALLET (WAJIB jika TRADING_ENABLED=true) ===
# Format bisa: base58 string, hex string, atau JSON array [1,2,3,...]
WALLET_PRIVATE_KEY=your_private_key_here

# === SOLANA RPC ===
# Default: mainnet-beta publik (lambat). Gunakan Helius/Alchemy untuk lebih cepat
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Contoh Helius RPC (lebih cepat):
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ============================================================
# TRADING CONFIG
# ============================================================

# Master switch - set true untuk mengaktifkan auto buy/sell
# DEFAULT: false (AMAN - hanya analisis tanpa trading)
TRADING_ENABLED=false

# Maksimal SOL per posisi (default: 0.5 SOL)
MAX_POSITION_SOL=0.5

# Take profit dalam persen (default: 40% profit = jual semua)
TAKE_PROFIT_PERCENT=40.0

# Stop loss dalam persen (default: 15% loss = jual semua)
STOP_LOSS_PERCENT=15.0

# Trailing stop mulai aktif setelah profit X% (default: 20%)
TRAILING_START_PERCENT=20.0

# Jarak trailing stop dari harga tertinggi (default: 5%)
TRAILING_DISTANCE_PERCENT=5.0

# Skor minimum untuk auto buy (default: 85.0)
MIN_SCORE_TO_BUY=85.0

# Likuiditas minimum USD untuk auto buy (default: $10,000)
MIN_LIQUIDITY_USD=10000.0

# Slippage default dalam persen (default: 1.0%)
DEFAULT_SLIPPAGE=1.0

# Maksimal posisi aktif bersamaan (default: 5)
MAX_POSITIONS=5

# ============================================================
# PAPER TRADING CONFIG (Simulasi tanpa uang nyata)
# ============================================================

# Aktifkan paper trading (simulasi) - AMAN, tidak pakai uang nyata
# Bisa diaktifkan bersamaan dengan atau tanpa TRADING_ENABLED
PAPER_TRADING_ENABLED=false

# Saldo virtual SOL untuk simulasi (default: 10 SOL)
# Ini adalah uang virtual, bukan SOL sungguhan
PAPER_BALANCE_SOL=10.0

# Interval laporan otomatis (default: 3600 detik = 1 jam)
# Bot akan kirim ringkasan performa paper trading ke Telegram setiap X detik
PAPER_REPORT_INTERVAL_SECS=3600

# Catatan: Parameter lain (TP, SL, Trailing, dll) diambil dari konfigurasi
# trading utama di atas (MAX_POSITION_SOL, TAKE_PROFIT_PERCENT, dll)

# ============================================================
# BACKTESTING CONFIG (cargo run -- --backtest)
# ============================================================

# Jumlah token yang dianalisis dalam satu sesi backtest (default: 150)
BACKTEST_TOKEN_LIMIT=150

# Umur minimum token dalam jam (default: 6 jam)
# Token yang terlalu baru belum punya cukup data historis
BACKTEST_MIN_AGE_HOURS=6

# Umur maksimum token dalam jam (default: 72 jam = 3 hari)
# Token yang terlalu lama tidak relevan untuk strategi ini
BACKTEST_MAX_AGE_HOURS=72

# Likuiditas minimum untuk ikut backtest (default: $5,000)
BACKTEST_MIN_LIQUIDITY=5000.0

# Volume minimum 24 jam untuk ikut backtest (default: $10,000)
BACKTEST_MIN_VOLUME=10000.0

# Harga SOL dalam USD (untuk kalkulasi ukuran posisi, default: 170)
SOL_PRICE_USD=170.0
