# ============================================================
# BASOL BOT v3.0 — KONFIGURASI UTAMA
# Edit file ini, lalu restart workflow untuk apply perubahan.
# File ini override semua setting platform Replit.
#
# CATATAN: API keys (HELIUS, TELEGRAM) disimpan di Replit Secrets
# agar tidak bocor — tidak perlu di-set di sini.
# ============================================================

# ============================================================
# TRADING UTAMA
# ============================================================

# Master switch live trading — set true hanya jika WALLET_PRIVATE_KEY sudah diset di Secrets
TRADING_ENABLED=false

# Solana RPC URL — uncomment baris Helius untuk lebih cepat
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=ISI_HELIUS_KEY_DI_SINI

# ============================================================
# PAPER TRADING (simulasi tanpa uang nyata)
# Paper dan live pakai konfigurasi yang SAMA di bawah ini
# ============================================================

PAPER_TRADING_ENABLED=true

# Saldo virtual SOL — set sama dengan modal nyata agar simulasi akurat
PAPER_BALANCE_SOL=0.1

# Interval laporan otomatis ke Telegram (detik) — default 1 jam
PAPER_REPORT_INTERVAL_SECS=3600

# ============================================================
# STRATEGI TRADING — SCALPING (berlaku identik untuk PAPER & LIVE)
# Break-even ~3.81% (fee jaringan + slippage 0.03 SOL)
# Urutan exit: TP1 +8% → TP2 +15% → Trailing +16% → Final TP +25% → SL -6%
# ============================================================

# Maksimal SOL per posisi
MAX_POSITION_SOL=0.03

# Ukuran posisi minimum
MIN_POSITION_SOL=0.03

# Skor minimum untuk auto buy (0-100) — berlaku identik untuk paper DAN live
# Bot akan auto-adjust nilai ini tiap jam berdasarkan win rate
# Scoring breakdown: Holder(max 25) + Liquidity(20) + Whale(20) + Technical(10) + Security(10) + Social(10) + Lifecycle(5)
# Token baru Solana nyata rata-rata skor 35-55 tergantung kondisi market.
# 45 = default realistis | 55 = selektif | 65+ = sangat jarang trade | 85+ = hampir tidak pernah
MIN_SCORE_TO_BUY=45.0

# Likuiditas minimum pool USD untuk beli
MIN_LIQUIDITY_USD=10000.0

# Slippage default dalam persen
DEFAULT_SLIPPAGE=1.5

# Maksimal posisi aktif bersamaan
MAX_POSITIONS=2

# ============================================================
# TAKE PROFIT & STOP LOSS
# ============================================================

# TP final — jual semua sisa posisi di level ini
# Scalping: ambil cepat di 25%, bukan menunggu 35%
TAKE_PROFIT_PERCENT=25.0

# Stop loss — selalu jual 100% sekaligus
# 6% lebih ketat → cut loss lebih cepat, kurangi drawdown scalping
STOP_LOSS_PERCENT=6.0

# Trailing stop mulai aktif setelah profit X%
# Harus > TP2_PERCENT (15%) agar urutan exit benar.
# 16% → trailing aktif tepat setelah TP2 fire.
# Floor profit setelah TP2: 16% × (1 - 3%) = +15.5%
TRAILING_START_PERCENT=16.0

# Jarak trailing stop dari harga tertinggi (persen)
# 3% lebih ketat → capture profit lebih banyak di scalping
TRAILING_DISTANCE_PERCENT=3.0

# Time exit: keluar otomatis jika posisi stuck lebih dari X menit
# 25 menit → turnover lebih cepat untuk scalping
MAX_HOLD_MINUTES=25

# Threshold P&L untuk time exit (keluar jika profit < nilai ini setelah MAX_HOLD_MINUTES)
# 1.5% → exit lebih agresif kalau token tidak bergerak
TIME_EXIT_THRESHOLD_PCT=1.5

# ============================================================
# 3-STAGE TAKE PROFIT (partial sell bertahap)
# Set TP1_PERCENT=0 untuk nonaktifkan dan pakai TP tunggal saja
# ============================================================

# Tahap 1: jual 33% dari posisi saat profit +8%
# 8% sudah aman di atas break-even 3.81% — lock profit lebih cepat
TP1_PERCENT=8.0
TP1_SELL_PERCENT=33.0

# Tahap 2: jual 50% dari SISA posisi saat profit +15%
TP2_PERCENT=15.0
TP2_SELL_PERCENT=50.0

# ============================================================
# SMART PROTECTION v3.0
# ============================================================

# Circuit Breaker: pause beli setelah N loss berturut-turut
# 4 lebih toleran — scalping volume lebih tinggi, 3 terlalu sensitif
CIRCUIT_BREAKER_LOSSES=4

# Durasi pause circuit breaker dalam jam
CIRCUIT_BREAKER_PAUSE_HOURS=1

# Peak Hours Filter: hanya beli saat jam volume tertinggi (13-17 & 20-00 UTC)
PEAK_HOURS_ONLY=true

# Momentum Filter: skip token yang sudah pump lebih dari X% dalam 1 jam
MOMENTUM_MAX_PCT=20.0

# ============================================================
# BACKTESTING (cargo run -- --backtest)
# ============================================================

BACKTEST_TOKEN_LIMIT=150
BACKTEST_MIN_AGE_HOURS=6
BACKTEST_MAX_AGE_HOURS=72
BACKTEST_MIN_LIQUIDITY=5000.0
BACKTEST_MIN_VOLUME=10000.0

# Skor minimum khusus backtest — HARUS lebih rendah dari MIN_SCORE_TO_BUY.
# Backtest scoring (estimate_score) tidak punya data Helius (security/holder),
# sehingga max skor ~90. Nilai 62 setara selektivitas yang sama dengan live 85.
BACKTEST_MIN_SCORE=62.0

# ============================================================
# OFF-PEAK TRADING
# Aktifkan trading di luar jam peak (13-17 & 20-00 UTC) dengan filter lebih ketat.
# Hanya berlaku jika PEAK_HOURS_ONLY=true.
# ============================================================

# Master switch: izinkan trade di luar jam peak dengan filter ketat
OFF_PEAK_TRADING_ENABLED=true

# Skor minimum off-peak — lebih tinggi dari peak (45) untuk kompensasi volume lebih rendah
OFF_PEAK_MIN_SCORE=55.0

# Likuiditas minimum off-peak — lebih tinggi untuk kurangi slippage di market sepi
OFF_PEAK_MIN_LIQUIDITY=15000.0

# Maksimal posisi aktif di luar jam peak — lebih sedikit untuk kurangi risiko
OFF_PEAK_MAX_POSITIONS=1

# Momentum filter off-peak — lebih ketat karena pump palsu lebih sering di jam sepi
OFF_PEAK_MOMENTUM_MAX_PCT=15.0

# ============================================================
# MISC
# ============================================================

# Harga awal SOL dalam USD (bot update otomatis dari Binance tiap 5 menit)
SOL_PRICE_USD=170.0
