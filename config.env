# ============================================================
# BASOL BOT v3.0 — KONFIGURASI UTAMA
# Edit file ini, lalu restart workflow untuk apply perubahan.
# File ini override semua setting platform Replit.
#
# CATATAN: API keys (HELIUS, TELEGRAM) disimpan di Replit Secrets
# agar tidak bocor — tidak perlu di-set di sini.
# ============================================================

# ============================================================
# TRADING UTAMA
# ============================================================

# Master switch live trading — set true hanya jika WALLET_PRIVATE_KEY sudah diset di Secrets
TRADING_ENABLED=false

# Solana RPC URL — uncomment baris Helius untuk lebih cepat
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=ISI_HELIUS_KEY_DI_SINI

# ============================================================
# PAPER TRADING (simulasi tanpa uang nyata)
# Paper dan live pakai konfigurasi yang SAMA di bawah ini
# ============================================================

PAPER_TRADING_ENABLED=true

# Saldo virtual SOL — set sama dengan modal nyata agar simulasi akurat
PAPER_BALANCE_SOL=0.1

# Interval laporan otomatis ke Telegram (detik) — 30 menit untuk pantau progress lebih sering
PAPER_REPORT_INTERVAL_SECS=1800

# ============================================================
# STRATEGI TRADING — SCALPING AGRESIF (peak hours only)
# Break-even ~3.81% (fee jaringan + slippage 0.03 SOL)
# Urutan exit: TP1 +6% → TP2 +15% → Trailing +16% → Final TP +25% → SL -5%
# ============================================================

# Maksimal SOL per posisi
MAX_POSITION_SOL=0.03

# Ukuran posisi minimum — lebih rendah dari MAX agar dynamic sizing aktif
# Score 40-70 → 0.015 SOL (konservatif), score 80+ → 0.02-0.03 SOL (agresif)
MIN_POSITION_SOL=0.015

# Skor minimum untuk auto buy (0-100)
# Diturunkan 45→40: +50% lebih banyak sinyal entry di peak hours
# Token baru Solana nyata rata-rata skor 35-55 tergantung kondisi market.
MIN_SCORE_TO_BUY=40.0

# Likuiditas minimum pool USD untuk beli
# Diturunkan 10000→7000: lebih banyak token baru lolos filter
MIN_LIQUIDITY_USD=7000.0

# Slippage default dalam persen
DEFAULT_SLIPPAGE=1.5

# Maksimal posisi aktif bersamaan
# Dinaikkan 2→3: 3 posisi sekaligus = 3x eksposur modal
MAX_POSITIONS=3

# ============================================================
# TAKE PROFIT & STOP LOSS
# ============================================================

# TP final — jual semua sisa posisi di level ini
TAKE_PROFIT_PERCENT=25.0

# Stop loss — selalu jual 100% sekaligus
STOP_LOSS_PERCENT=5.0

# Trailing stop mulai aktif setelah profit X%
# Harus > TP2_PERCENT (15%) agar urutan exit benar.
TRAILING_START_PERCENT=16.0

# Jarak trailing stop dari harga tertinggi (persen)
# Diperketat 3→2.5%: kunci profit lebih banyak saat token pump
TRAILING_DISTANCE_PERCENT=2.5

# Time exit: keluar otomatis jika posisi stuck lebih dari X menit
# Dinaikkan 25→40: beri waktu lebih untuk token berkembang
MAX_HOLD_MINUTES=40

# Threshold P&L untuk time exit
TIME_EXIT_THRESHOLD_PCT=1.5

# ============================================================
# 3-STAGE TAKE PROFIT (partial sell bertahap)
# Set TP1_PERCENT=0 untuk nonaktifkan dan pakai TP tunggal saja
# ============================================================

# Tahap 1: jual 33% dari posisi saat profit +6%
# Diturunkan 8→6%: break-even protection aktif lebih cepat, lock profit lebih sering
TP1_PERCENT=6.0
TP1_SELL_PERCENT=33.0

# Tahap 2: jual 50% dari SISA posisi saat profit +15%
TP2_PERCENT=15.0
TP2_SELL_PERCENT=50.0

# ============================================================
# SMART PROTECTION v3.0
# ============================================================

# Circuit Breaker: pause beli setelah N loss berturut-turut
# Dinaikkan 3→5: kurangi jeda paksa agar bot tetap aktif saat peak hours
CIRCUIT_BREAKER_LOSSES=5

# Durasi pause circuit breaker dalam jam
CIRCUIT_BREAKER_PAUSE_HOURS=1

# ============================================================
# PERLINDUNGAN MODAL (Capital Protection)
# ============================================================

# Break-even stop setelah TP1 fire
BREAKEVEN_AFTER_TP1=true

# Batas kerugian maksimal per hari UTC (dalam % dari saldo awal)
DAILY_MAX_LOSS_PCT=8.0

# Peak Hours Filter: hanya beli saat jam volume tertinggi (13-17 & 20-00 UTC)
PEAK_HOURS_ONLY=true

# Momentum Filter: skip token yang sudah pump lebih dari X% dalam 1 jam
# Dinaikkan 40→55%: tangkap lebih banyak entry di early momentum window
MOMENTUM_MAX_PCT=55.0

# ============================================================
# BACKTESTING (cargo run -- --backtest)
# ============================================================

BACKTEST_TOKEN_LIMIT=150
BACKTEST_MIN_AGE_HOURS=6
BACKTEST_MAX_AGE_HOURS=72
BACKTEST_MIN_LIQUIDITY=5000.0
BACKTEST_MIN_VOLUME=10000.0
BACKTEST_MIN_SCORE=62.0

# ============================================================
# OFF-PEAK TRADING — DINONAKTIFKAN
# Fokus full di peak hours (13-17 & 20-00 UTC) saja
# ============================================================

OFF_PEAK_TRADING_ENABLED=false
OFF_PEAK_MIN_SCORE=55.0
OFF_PEAK_MIN_LIQUIDITY=15000.0
OFF_PEAK_MAX_POSITIONS=1
OFF_PEAK_MOMENTUM_MAX_PCT=30.0

# ============================================================
# MISC
# ============================================================

# Harga awal SOL dalam USD (bot update otomatis dari Binance tiap 5 menit)
SOL_PRICE_USD=170.0
