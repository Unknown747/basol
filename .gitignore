# ── Rust ────────────────────────────────────────────────────
/target/
# Cargo.lock intentionally tracked — binary crate needs reproducible builds
# Cargo.lock

# ── Bot runtime state (generated at runtime, never commit) ──
bot_data.json
paper_state.json
backtest_*.json
compare_*.json

# ── Secrets (never commit) ──────────────────────────────────
.env

# ── User config (local overrides, not committed) ─────────────
config.env

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

