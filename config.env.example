# ============================================================
# BASOL BOT v3.0 — KONFIGURASI UTAMA
# Salin file ini: cp config.env.example config.env
# Edit config.env sesuai kebutuhan, lalu restart bot.
#
# File ini override semua setting platform (Replit env vars).
# API keys sensitif (Helius, Telegram, Wallet) disimpan di
# Replit Secrets atau di .env — tidak perlu di sini.
# ============================================================

# ============================================================
# TRADING UTAMA
# ============================================================

# Master switch live trading
# false = analisis saja (aman) | true = eksekusi on-chain dengan SOL nyata
TRADING_ENABLED=false

# Solana RPC URL
# Public (lambat, rate-limited):
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Helius (direkomendasikan untuk produksi — lebih cepat & stabil):
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=ISI_KEY_DI_SINI

# ============================================================
# PAPER TRADING (simulasi tanpa uang nyata)
# Paper dan live pakai konfigurasi IDENTIK di bawah ini
# ============================================================

# Aktifkan simulasi (true = aman, tidak ada SOL nyata digunakan)
PAPER_TRADING_ENABLED=true

# Saldo virtual SOL — set sama dengan modal nyata agar simulasi akurat
PAPER_BALANCE_SOL=0.1

# Interval laporan otomatis ke Telegram (detik)
# 3600 = 1 jam | 1800 = 30 menit | 86400 = 1 hari
PAPER_REPORT_INTERVAL_SECS=3600

# ============================================================
# STRATEGI TRADING — berlaku identik untuk PAPER & LIVE
# ============================================================

# SOL per posisi (maksimal)
MAX_POSITION_SOL=0.03

# SOL per posisi (minimal) — set sama dengan MAX untuk posisi tetap
MIN_POSITION_SOL=0.03

# Skor minimum token untuk auto buy (0–100)
# Lebih tinggi = lebih selektif. Bot auto-adjust tiap jam dari win rate.
MIN_SCORE_TO_BUY=89.0

# Likuiditas pool minimum dalam USD
MIN_LIQUIDITY_USD=5000.0

# Slippage default (%)
DEFAULT_SLIPPAGE=1.5

# Maksimal posisi aktif bersamaan
MAX_POSITIONS=2

# ============================================================
# TAKE PROFIT & STOP LOSS
# ============================================================

# TP Final — jual semua sisa posisi di level ini
TAKE_PROFIT_PERCENT=35.0

# Stop Loss — jual 100% seketika (tidak pernah partial)
STOP_LOSS_PERCENT=8.0

# Trailing stop mulai aktif setelah profit mencapai X%
TRAILING_START_PERCENT=12.0

# Jarak trailing stop dari harga tertinggi (%)
TRAILING_DISTANCE_PERCENT=3.0

# Time Exit: keluar otomatis jika posisi stuck lebih dari X menit
# 0 = nonaktif (tahan posisi selamanya sampai TP/SL/Trailing)
MAX_HOLD_MINUTES=40

# Threshold untuk time exit — hanya keluar jika profit < nilai ini
TIME_EXIT_THRESHOLD_PCT=3.0

# ============================================================
# 3-STAGE TAKE PROFIT (partial sell bertahap)
# Nonaktifkan: set TP1_PERCENT=0 dan TP2_PERCENT=0
# ============================================================

# Tahap 1: jual X% dari posisi saat profit mencapai Y%
TP1_PERCENT=12.0
TP1_SELL_PERCENT=33.0

# Tahap 2: jual X% dari SISA posisi saat profit mencapai Y%
TP2_PERCENT=20.0
TP2_SELL_PERCENT=50.0

# ============================================================
# SMART PROTECTION v3.0
# ============================================================

# Circuit Breaker: pause beli setelah N loss berturut-turut
# Sell posisi aktif tetap jalan selama pause
CIRCUIT_BREAKER_LOSSES=3
CIRCUIT_BREAKER_PAUSE_HOURS=2

# Peak Hours Filter: hanya beli saat jam volume tinggi Solana
# true = hanya beli 13:00-17:00 UTC dan 20:00-00:00 UTC
# false = beli kapan saja (default)
PEAK_HOURS_ONLY=false

# Momentum Filter: skip token yang sudah pump > X% dalam 1 jam
# Entry terlambat = risiko dump tinggi
MOMENTUM_MAX_PCT=30.0

# ============================================================
# BACKTESTING (cargo run -- --backtest)
# ============================================================

BACKTEST_TOKEN_LIMIT=150
BACKTEST_MIN_AGE_HOURS=6
BACKTEST_MAX_AGE_HOURS=72
BACKTEST_MIN_LIQUIDITY=5000.0
BACKTEST_MIN_VOLUME=10000.0

# ============================================================
# MISC
# ============================================================

# Harga SOL awal dalam USD (bot update otomatis dari Binance tiap 5 menit)
SOL_PRICE_USD=170.0
